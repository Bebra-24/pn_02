<Window x:Class="AgroControlClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АГРОКОНТРОЛЬ - Модуль технолога"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Меню -->
        <Border Grid.Column="0" Background="#2C3E50">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="#1A252F" Height="70">
                        <TextBlock Text="АГРОКОНТРОЛЬ" 
                                   FontSize="18" FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Background="#3D566E" Margin="0,10,0,10" Padding="15,10">
                        <StackPanel>
                            <TextBlock x:Name="txtUserName" Text="Иванов Иван Петрович" Foreground="White" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="txtUserRole" Text="Технолог" Foreground="#BDC3C7" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnProducts" Content="📦 Карточки продукции" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnRecipes" Content="📋 Рецептуры" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnTechCards" Content="🗺️ Технологические карты" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnOrders" Content="📄 Производственные заказы" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnBatches" Content="🏭 Производственные партии" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnExtruder" Content="⚙️ Настройка экструдера" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnMonitor" Content="📊 Мониторинг партий" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnDeviations" Content="⚠️ Анализ отклонений" Style="{StaticResource MenuButton}"/>
                    <Button x:Name="btnReports" Content="📈 Отчеты" Style="{StaticResource MenuButton}"/>

                    <Separator Background="#3D566E" Height="1" Margin="10,20"/>

                    <Button x:Name="btnLogout" Content="🚪 Выход" Style="{StaticResource MenuButton}" Foreground="#E53935"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2E7D32">
                <Grid Margin="20,0">
                    <TextBlock x:Name="lblTitle" Text="Главная" 
                               FontSize="18" FontWeight="Bold" 
                               Foreground="White" VerticalAlignment="Center"/>
                    <Button x:Name="btnRefresh" Content="🔄" Width="30" Height="30" 
                            Background="Transparent" BorderThickness="0" 
                            Foreground="White" Cursor="Hand" 
                            HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <ContentControl x:Name="ContentContainer" Grid.Row="1" Background="#F0F0F0"/>
        </Grid>
    </Grid>
</Window>