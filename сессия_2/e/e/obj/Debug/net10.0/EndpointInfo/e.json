          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "code": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          },
          "name": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "productType": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "releaseForm": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "unit": {
            "maxLength": 10,
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "QualityParameterDto": {
        "type": "object",
        "properties": {
          "parameterName": {
            "type": "string",
            "nullable": true
          },
          "measuredValue": {
            "type": "number",
            "format": "double"
          },
          "unit": {
            "type": "string",
            "nullable": true
          },
          "comment": {
            "type": "string",
            "nullable": true
          }
